# Copy to web/.env (do NOT commit secrets)

# App
APP_ENV=local
APP_URL=http://localhost:8000
APP_NAME=Perfushopping

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=perfushopping
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Mercado Pago (minorista)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# SMTP (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=clientes@perfushopping.com.ar
SMTP_PASS=
MAIL_FROM=clientes@perfushopping.com.ar
MAIL_FROM_NAME=perfushopping

# Admin bootstrap
ADMIN_EMAIL=clientes@perfushopping.com.ar

# VFP sync webservice
SYNC_TOKEN=

# Optional separate token for multipart upload (if empty, SYNC_TOKEN is used)
UPLOAD_TOKEN=

# IA descripciones de productos
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT=30
